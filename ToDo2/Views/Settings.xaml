<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDo2.Views.Settings"
             Title="Settings">
    <VerticalStackLayout>
        <Label Text="Settings Page"
               FontSize="24"
               HorizontalOptions="Center" />

        <Entry x:Name="NombreTarea" Placeholder="Nombre de la tarea" />

        <Button Text="Agregar Tipo"
                    Clicked="OnAgregarTipoClicked"
                    Background="Black"
                    TextColor="White"
        />

        <Label Text="Tipos de Tareas"
               FontSize="20"
               Margin="0,20,0,10" />
        <CollectionView x:Name="ListaTiposView" ItemsSource="{Binding TiposTodo}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*, Auto" Padding="10">
                        <Label Text="{Binding .}" VerticalOptions="Center" FontSize="16" />

                        <Button Grid.Column="1" 
                            Text="X" 
                            BackgroundColor="Red" 
                            TextColor="White"
                            HeightRequest="35"
                            WidthRequest="35"
                            CornerRadius="17"
                            Clicked="OnEliminarTipoClicked"
                            CommandParameter="{Binding .}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>