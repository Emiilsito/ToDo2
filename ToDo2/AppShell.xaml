<?xml version="1.0" encoding="UTF-8" ?>
<Shell
	x:Class="ToDo2.AppShell"
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:local="clr-namespace:ToDo2"
	xmlns:views="clr-namespace:ToDo2.Views"
	Title="ToDo2">

	<TabBar>
		<ShellContent
			Title="Tareas"
			Icon="iconblank.png"
			ContentTemplate="{DataTemplate views:MainPage}" />
		<ShellContent
			Title="Sample"
			Icon="iconsample.png"
			ContentTemplate="{DataTemplate views:SamplePage}" />
        <ShellContent
            Title="Settings"
            Icon="iconsettings.png"
            ContentTemplate="{DataTemplate views:Settings}" />
    </TabBar>
</Shell>
